}
else if (transition == 38) {
log_transition("4634_5");
fire_4634_5();
}
else {
console.log("Selected illegal transition; should never happen.");
}
simulator_loop(steps - 1);
}

var simulator = function(){
init();
update_enabled_4656();
update_enabled_tau_5();
update_enabled_4688_cmd();
update_enabled_4657_common();
update_enabled_4624_9();
update_enabled_4801();
update_enabled_4800();
update_enabled_4624_7();
update_enabled_4609();
update_enabled_init_t();
update_enabled_tau_4();
update_enabled_4624_8();
update_enabled_4625_9_8_2_7_3();
update_enabled_tau_1();
update_enabled_4658();
update_enabled_1100();
update_enabled_4657_registry();
update_enabled_4634_2_7_8_9();
update_enabled_4672();
update_enabled_4648();
update_enabled_tau_9();
update_enabled_4634_3();
update_enabled_tau_7();
update_enabled_4663();
update_enabled_4688_priv();
update_enabled_4624_3();
update_enabled_4624_5();
update_enabled_4624_2();
update_enabled_tau_6();
update_enabled_4625_4_5();
update_enabled_4688_conhost();
update_enabled_4624_4();
update_enabled_4634_4();
update_enabled_tau_8();
update_enabled_4608();
update_enabled_4688_unpriv();
update_enabled_tau_2();
update_enabled_tau_3();
update_enabled_4634_5();

globalStore.trace += "<trace>\n";

simulator_loop(20);

globalStore.trace += "</trace>\n";

console.log(globalStore.trace);

return false;
}

var dist = Infer({
method: 'forward', 
samples: 20000,
},simulator);

// Extract the samples from the distribution
var samplesArray = dist.samples;
var params = dist.params;

// Convert the samples array to a JSON string
var jsonString = JSON.stringify({"dist":dist});

// Output the JSON string
jsonString;

fire_4624_3();
}
else if (transition == 26) {
log_transition("4624_5");
fire_4624_5();
}
else if (transition == 27) {
log_transition("4624_2");
fire_4624_2();
}
else if (transition == 28) {
log_transition("tau_6");
fire_tau_6();
}
else if (transition == 29) {
log_transition("4625_4_5");
fire_4625_4_5();
}
else if (transition == 30) {
log_transition("4688_conhost");

var Predicates = {};

//fired at least N times
Predicates.firedNTimes = function(trace, id, n) {
  return trace.counts[id] >= n;
};

//fired at least once
Predicates.firedAtLeastOnce = function(trace, id) {
  return trace.counts[id] >= 1;
};

//all ids in list should be fired at least once
Predicates.firedGroupAllOnce = function(trace, ids) {
  for (var i = 0; i < ids.length; i++) {
    if (trace.counts[ids[i]] < 1) {
      return false;
    }
  }
  return true;
};

Predicates;
